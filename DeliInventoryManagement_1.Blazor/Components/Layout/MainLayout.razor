@inherits LayoutComponentBase
@implements IDisposable
@using DeliInventoryManagement_1.Blazor.Services.Auth
@inject AuthService Auth
@inject AuthState State
@inject NavigationManager Nav

<div class="page">
    <main>
        <header class="topbar">     
            <div class="topbar-left">
                <span class="brand">🥪 DeliInventoryManagement
                </span>
            </div>

            <nav class="topbar-center">
                <NavLink class="toplink" href="" Match="NavLinkMatch.All">Home</NavLink>
                <NavLink class="toplink" href="dashboard">Dashboard</NavLink>
                <NavLink class="toplink" href="sales">Sales</NavLink>
                <NavLink class="toplink" href="stock">Stock</NavLink>
                <NavLink class="toplink" href="restocks">Restocks</NavLink>
                <NavLink class="toplink" href="reports">Reports</NavLink>
            </nav>

            <div class="topbar-right">
                <NavLink class="toplink" href="about">About</NavLink>

                @if (!State.IsReady)
                {
                    <span class="toplink text-muted">Loading session...</span>
                }
                else if (State.IsAuthenticated)
                {
                    <button class="toplink btn btn-link" @onclick="DoLogout">Logout</button>
                }
                else
                {
                    <NavLink class="toplink" href="login">Login</NavLink>
                }
            </div>
        </header>

        <article class="content">
            @Body
        </article>
    </main>
</div>

@code {
    private bool _authInitialized;

    protected override void OnInitialized()
    {
        State.OnChange += StateHasChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _authInitialized)
            return;

        _authInitialized = true;

        try
        {
            await Auth.InitializeFromStorageAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"MAINLAYOUT AUTH INIT ERROR: {ex.Message}");
            State.Clear();
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task DoLogout()
    {
        await Auth.LogoutAsync();
        Nav.NavigateTo("/login");
    }

    public void Dispose()
    {
        State.OnChange -= StateHasChanged;
    }
}