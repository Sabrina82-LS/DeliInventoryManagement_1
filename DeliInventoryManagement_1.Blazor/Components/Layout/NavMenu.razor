@inject DeliInventoryManagement_1.Blazor.Services.Auth.AuthService Auth
@inject DeliInventoryManagement_1.Blazor.Services.Auth.AuthState AuthState
@inject NavigationManager Nav

<div class="top-row ps-3 navbar navbar-dark" style="flex-wrap:wrap;">
    <div class="container-fluid d-flex justify-content-between align-items-center">
        <a class="navbar-brand" href="">DeliInventoryManagement_1</a>

        <!-- AUTH BUTTON (Top Right) -->
        @if (AuthState.IsAuthenticated)
        {
            <div class="d-flex align-items-center gap-2">
                <span class="text-white small">
                    Hello, @AuthState.Name
                </span>

                <button class="btn btn-sm btn-outline-light" @onclick="Logout">
                    Logout
                </button>
            </div>
        }
        else
        {
            <NavLink class="btn btn-sm btn-outline-light" href="login">
                Login
            </NavLink>
        }
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="flex-column">

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu"></span>
                Home
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="dashboard">
                <span class="bi bi-speedometer2-nav-menu"></span>
                Dashboard
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="sales">
                <span class="bi bi-plus-square-fill-nav-menu"></span>
                Sales
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="stock">
                <span class="bi bi-box-seam-nav-menu"></span>
                Stock
            </NavLink>
        </div>

       <div class="nav-item px-3">
            <NavLink class="nav-link" href="restocks">
                <span class="bi bi-arrow-repeat-nav-menu"></span>
                Restocks
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="products">
                <span class="bi bi-box-seam-nav-menu"></span>
                Products
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="purchase-orders">
                <span class="bi bi-list-nested-nav-menu"></span>
                Purchase Orders
            </NavLink>
        </div>



        <div class="nav-item px-3 mt-3">
            <NavLink class="nav-link" href="reports" Match="NavLinkMatch.Prefix">
                <span class="bi bi-bar-chart-line-fill-nav-menu"></span>
                Reports
            </NavLink>
        </div>

        <div class="nav-item px-3 ms-4">
            <NavLink class="nav-link" href="reports/sales">
                <span class="bi bi-graph-up-nav-menu"></span>
                Sales Report
            </NavLink>
        </div>

        <div class="nav-item px-3 ms-4">
            <NavLink class="nav-link" href="reports/restocks">
                <span class="bi bi-graph-down-nav-menu"></span>
                Restocks Report
            </NavLink>
        </div>

    </nav>
</div>



@code {
    private async Task Logout()
    {
        await Auth.LogoutAsync();
        Nav.NavigateTo("/login", true);
    }
}