@page "/dashboard"
@implements IDisposable
@using DeliInventoryManagement_1.Blazor.Models.V5
@using DeliInventoryManagement_1.Blazor.Services.Auth
@using DeliInventoryManagement_1.Blazor.Services.IService

@inject IDashboardService DashboardService
@inject IPurchaseOrderService PurchaseOrderService
@inject AuthState AuthState
@inject NavigationManager NavManager

<AuthGuard>
    <div class="dashboard-wrap">
        <div class="dashboard-header">
            <div>
                <h1 class="dashboard-title">Dashboard</h1>
                <p class="dashboard-subtitle">Overview of stock, suppliers, sales, and reorder activity.</p>
            </div>
        </div>

        @if (isLoading)
        {
            <div class="panel">
                <p class="muted">Loading...</p>
            </div>
        }
        else if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="panel panel-danger">
                <strong>Error:</strong> @errorMessage
            </div>
        }
        else
        {
            <section class="kpi-grid">
                <div class="kpi-card">
                    <div class="kpi-label">Total Products</div>
                    <div class="kpi-value">@totalProducts</div>
                </div>

                <div class="kpi-card">
                    <div class="kpi-label">Total Stock Quantity</div>
                    <div class="kpi-value">@totalStockQty</div>
                </div>

                <div class="kpi-card">
                    <div class="kpi-label">Today's Sales</div>
                    <div class="kpi-value">
                        @(todaysSales == 0
                                            ? "€0.00"
                                            : todaysSales.ToString("C", new System.Globalization.CultureInfo("en-IE")))
                </div>
                <div class="kpi-footnote">Based on V5 sales records</div>
            </div>

                <div class="kpi-card">
                    <div class="kpi-label">Suppliers</div>
                    <div class="kpi-value">@supplierCount</div>
                    <div class="kpi-footnote">Active suppliers</div>
                </div>
            </section>

            <section class="dashboard-grid">
                <div class="panel low-stock-panel">
                    <div class="panel-header-inline">
                        <div>
                            <h2 class="panel-title">Low Stock Overview</h2>
                            <p class="panel-subtitle">
                                View items that still need reorder and items already covered by pending purchase orders.
                            </p>
                        </div>

                        <button type="button" class="btn-view-all" @onclick="GoToPurchaseOrdersPage">
                            View All
                        </button>
                    </div>

                    <div class="low-stock-summary">
                        <div class="summary-chip summary-chip-danger">
                            <span class="summary-chip-label">Needs Reorder</span>
                            <span class="summary-chip-value">@needsReorderItems.Count</span>
                        </div>

                        <div class="summary-chip summary-chip-warning">
                            <span class="summary-chip-label">Pending Low Stock</span>
                            <span class="summary-chip-value">@pendingLowStockItems.Count</span>
                        </div>

                        <div class="summary-chip summary-chip-neutral">
                            <span class="summary-chip-label">Pending POs</span>
                            <span class="summary-chip-value">@pendingPurchaseOrdersCount</span>
                        </div>

                        <div class="summary-chip summary-chip-success">
                            <span class="summary-chip-label">Completed POs</span>
                            <span class="summary-chip-value">@completedPurchaseOrdersCount</span>
                        </div>
                    </div>

                    <div class="low-stock-sections">
                        <div class="low-stock-section">
                            <div class="section-title-row">
                                <h3 class="section-title">Needs Reorder</h3>
                                <span class="section-count">@needsReorderItems.Count item(s)</span>
                            </div>

                        @if (needsReorderItems.Count == 0)
                            {
                                <p class="muted small-muted">No items currently need a new reorder.</p>
                            }
                            else
                            {
                                <div class="table-wrap">
                                    <table class="table-clean low-stock-table">
                                        <thead>
                                            <tr>
                                                <th>Name</th>
                                                <th>Category</th>
                                                <th class="num">Quantity</th>
                                                <th class="num">Reorder Level</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var item in needsReorderItems)
                                            {
                                                <tr>
                                                    <td class="product-name">@item.ProductName</td>
                                                    <td class="category-name">@item.CategoryName</td>
                                                    <td class="num">@item.CurrentQuantity</td>
                                                    <td class="num">@item.ReorderLevel</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                        </div>

                        <div class="low-stock-section">
                            <div class="section-title-row">
                                <h3 class="section-title">Pending Purchase Orders</h3>
                                <span class="section-count">@pendingLowStockItems.Count item(s)</span>
                            </div>

                            @if (pendingLowStockItems.Count == 0)
                            {
                                <p class="muted small-muted">No low-stock items are currently covered by pending purchase orders.</p>
                            }
                            else
                            {
                                <div class="table-wrap">
                                    <table class="table-clean low-stock-table">
                                        <thead>
                                            <tr>
                                                <th>Name</th>
                                                <th>Category</th>
                                                <th>Supplier</th>
                                                <th class="num">Quantity</th>
                                                <th class="num">Reorder Level</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var item in pendingLowStockItems)
                                            {
                                                <tr>
                                                    <td class="product-name">@item.ProductName</td>
                                                    <td class="category-name">@item.CategoryName</td>
                                                    <td>@item.SupplierName</td>
                                                    <td class="num">@item.CurrentQuantity</td>
                                                    <td class="num">@item.ReorderLevel</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <div class="panel quick-links-panel">
                    <div class="quick-links-header">
                        <h2 class="panel-title">Quick Links</h2>
                        <p class="panel-subtitle">Fast access to the main areas of the system.</p>
                    </div>

                    <div class="quick-links">
                        <NavLink class="quick-link btn-products" href="/products" Match="NavLinkMatch.Prefix">
                            <span>Products</span>
                        </NavLink>

                        <NavLink class="quick-link btn-stock" href="/stock" Match="NavLinkMatch.Prefix">
                            <span>Stock</span>
                        </NavLink>

                        <NavLink class="quick-link btn-sales" href="/sales" Match="NavLinkMatch.Prefix">
                            <span>Sales</span>
                        </NavLink>

                        <NavLink class="quick-link btn-restocks" href="/restocks" Match="NavLinkMatch.Prefix">
                            <span>Restocks</span>
                        </NavLink>

                        <NavLink class="quick-link btn-reports" href="/reports" Match="NavLinkMatch.Prefix">
                            <span>Reports</span>
                        </NavLink>

                        <NavLink class="quick-link btn-purchase-orders" href="/purchase-orders" Match="NavLinkMatch.Prefix">
                            <span>Purchase Orders</span>
                        </NavLink>
                    </div>
                </div>
            </section>
        }
    </div>
</AuthGuard>

@code {
    private bool isLoading = true;
    private bool loaded;
    private string? errorMessage;

    private int totalProducts;
    private int totalStockQty;
    private decimal todaysSales;
    private int supplierCount;

    private int pendingPurchaseOrdersCount;
    private int completedPurchaseOrdersCount;

    private List<ReorderListItemV5Dto> needsReorderItems = new();
    private List<ReorderListItemV5Dto> pendingLowStockItems = new();

    protected override void OnInitialized()
    {
        AuthState.OnChange += HandleAuthChanged;
    }

    private void HandleAuthChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (loaded)
            return;

        if (!AuthState.IsReady)
            return;

        if (!AuthState.IsAuthenticated)
        {
            NavManager.NavigateTo("/login?returnUrl=/dashboard");
            return;
        }

        loaded = true;
        await LoadDashboardAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadDashboardAsync()
    {
        try
        {
            isLoading = true;
            errorMessage = null;

            var products = await DashboardService.GetAllProductsAsync();
            var sales = await DashboardService.GetAllSalesAsync();
            var orders = await PurchaseOrderService.GetOrdersAsync();

            totalProducts = products.Count;
            totalStockQty = products.Sum(p => p.Quantity);

            needsReorderItems = await DashboardService.GetLowStockTop10Async();
            pendingLowStockItems = await DashboardService.GetPendingLowStockTop10Async();

            supplierCount = await DashboardService.GetSupplierCountAsync();

            pendingPurchaseOrdersCount = orders.Count(o =>
                string.Equals(o.Status, "Pending", StringComparison.OrdinalIgnoreCase));

            completedPurchaseOrdersCount = orders.Count(o =>
                string.Equals(o.Status, "Completed", StringComparison.OrdinalIgnoreCase));

            var today = DateTime.Today;

            todaysSales = sales
                .Where(s => s.Date.Date == today)
                .Sum(s => s.Total);
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading dashboard: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void GoToPurchaseOrdersPage()
    {
        NavManager.NavigateTo("/purchase-orders");
    }

    public void Dispose()
    {
        AuthState.OnChange -= HandleAuthChanged;
    }
}