@page "/sales"

@using DeliInventoryManagement_1.Blazor.Models.CreateLineRequest
@using DeliInventoryManagement_1.Blazor.Models.CreateRequest
@using DeliInventoryManagement_1.Blazor.Models.V5
@using DeliInventoryManagement_1.Blazor.Services.IService

@inject IDashboardService DashboardService
@inject ISalesService SalesService
@inject NavigationManager Nav

<AuthGuard>
    <div class="sales-wrap">
        <h1 class="sales-title">Sales</h1>

        @if (isLoading)
        {
            <div class="panel">
                <p class="muted">Loading products...</p>
            </div>
        }
        else if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="panel panel-danger">
                <strong>Error:</strong> @errorMessage
            </div>
        }
        else
        {
            <div class="sales-grid">
                <section class="panel">
                    <div class="panel-head">
                        <h2 class="panel-title">New Sale</h2>
                        <p class="panel-subtitle">Select a product, set quantity, and add the line.</p>
                    </div>

                    <div class="form-grid">
                        <div class="field">
                            <label class="form-label">Date</label>
                            <input type="date" class="form-control" @bind="saleDate" disabled="@isSaving" />
                        </div>

                        <div class="field field-wide">
                            <label class="form-label">Product</label>
                            <select class="form-select"
                                    value="@selectedProductId"
                                    @onchange="OnProductChanged"
                                    disabled="@isSaving">
                                <option value="">-- Select product --</option>
                                @foreach (var p in products)
                                {
                                    <option value="@p.Id">@p.Name (@p.CategoryName)</option>
                                }
                            </select>
                        </div>

                        <div class="field">
                            <label class="form-label">Quantity</label>
                            <input type="number"
                                   min="1"
                                   class="form-control"
                                   @bind="lineQuantity"
                                   disabled="@isSaving" />
                        </div>

                        <div class="field">
                            <label class="form-label">Unit Price</label>
                            <input type="text"
                                   class="form-control"
                                   value="@lineUnitPrice.ToString("0.00")"
                                   readonly />
                        </div>
                    </div>

                    <div class="actions-row">
                        <button class="btn btn-primary" @onclick="AddLine" disabled="@isSaving">
                            Add line
                        </button>
                    </div>

                    @if (!string.IsNullOrEmpty(lineError))
                    {
                        <div class="inline-error" role="alert">@lineError</div>
                    }
                </section>

                <section class="panel">
                    <div class="panel-head">
                        <h2 class="panel-title">Sale Lines</h2>
                        <p class="panel-subtitle">Review and remove lines before saving.</p>
                    </div>

                    @if (lines.Count == 0)
                    {
                        <div class="empty-state">
                            No lines added yet.
                        </div>
                    }
                    else
                    {
                        <div class="lines-box">
                            <table class="table table-sm align-middle mb-0">
                                <thead>
                                    <tr>
                                        <th>Product</th>
                                        <th class="text-end">Qty</th>
                                        <th class="text-end">Unit Price</th>
                                        <th class="text-end">Line Total</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var l in lines)
                                    {
                                        <tr>
                                            <td>@l.ProductName</td>
                                            <td class="text-end">@l.Quantity</td>
                                            <td class="text-end">@l.UnitPrice.ToString("0.00")</td>
                                            <td class="text-end">@l.Total.ToString("0.00")</td>
                                            <td class="text-end">
                                                <button class="btn btn-link btn-sm"
                                                        @onclick="() => RemoveLine(l)"
                                                        disabled="@isSaving">
                                                    Remove
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <div class="total-row">
                            <span>Total:</span>
                            <span class="total-value">@lines.Sum(l => l.Total).ToString("0.00")</span>
                        </div>
                    }

                    <div class="save-row">
                        <button class="btn btn-success"
                                @onclick="SaveSaleAsync"
                                disabled="@(lines.Count == 0 || isSaving)">
                            @(isSaving ? "Saving..." : "Save Sale")
                        </button>
                    </div>
                </section>
            </div>

            @if (!string.IsNullOrEmpty(saveMessage))
            {
                <div class="panel panel-info mt-3">
                    @saveMessage
                </div>
            }

            @if (!string.IsNullOrEmpty(saveError))
            {
                <div class="panel panel-danger mt-3">
                    @saveError
                </div>
            }
        }
    </div>
</AuthGuard>

@code {
    private bool isLoading;
    private bool isSaving;
    private string? errorMessage;

    private List<ProductV5Dto> products = new();

    private DateTime saleDate = DateTime.Today;
    private string selectedProductId = string.Empty;
    private int lineQuantity = 1;
    private decimal lineUnitPrice = 0m;
    private string? lineError;

    private string? saveMessage;
    private string? saveError;

    private sealed class SaleLineVm
    {
        public string ProductId { get; set; } = string.Empty;
        public string ProductName { get; set; } = string.Empty;
        public int Quantity { get; set; }
        public decimal UnitPrice { get; set; }
        public decimal Total => Quantity * UnitPrice;
    }

    private readonly List<SaleLineVm> lines = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadProductsAsync();
    }

    private async Task LoadProductsAsync()
    {
        try
        {
            isLoading = true;
            errorMessage = null;

            products = await DashboardService.GetAllProductsAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading products: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void OnProductChanged(ChangeEventArgs e)
    {
        selectedProductId = e.Value?.ToString() ?? string.Empty;
        lineError = null;
        saveMessage = null;
        saveError = null;

        if (string.IsNullOrWhiteSpace(selectedProductId))
        {
            lineUnitPrice = 0m;
            return;
        }

        var product = products.FirstOrDefault(p => p.Id == selectedProductId);

        if (product is null)
        {
            lineUnitPrice = 0m;
            lineError = "Selected product not found.";
            return;
        }

        lineUnitPrice = product.Price;
    }

    private void AddLine()
    {
        lineError = null;
        saveMessage = null;
        saveError = null;

        if (string.IsNullOrWhiteSpace(selectedProductId))
        {
            lineError = "Select a product.";
            return;
        }

        var product = products.FirstOrDefault(p => p.Id == selectedProductId);
        if (product is null)
        {
            lineError = "Selected product not found. Reload the page and try again.";
            return;
        }

        if (lineQuantity <= 0)
        {
            lineError = "Quantity must be greater than 0.";
            return;
        }

        if (lineUnitPrice <= 0)
        {
            lineError = "Unit Price must be greater than 0.";
            return;
        }

        lines.Add(new SaleLineVm
        {
            ProductId = product.Id,
            ProductName = product.Name,
            Quantity = lineQuantity,
            UnitPrice = lineUnitPrice
        });

        selectedProductId = string.Empty;
        lineQuantity = 1;
        lineUnitPrice = 0m;
    }

    private void RemoveLine(SaleLineVm line)
    {
        saveMessage = null;
        saveError = null;
        lines.Remove(line);
    }

    private async Task SaveSaleAsync()
    {
        saveMessage = null;
        saveError = null;
        lineError = null;

        if (lines.Count == 0)
        {
            saveError = "Add at least one line before saving.";
            return;
        }

        isSaving = true;

        try
        {
            var req = new CreateSaleRequest
            {
                Date = saleDate,
                Lines = lines.Select(l => new CreateSaleLineRequest
                {
                    ProductId = l.ProductId,
                    ProductName = l.ProductName,
                    Quantity = l.Quantity,
                    UnitPrice = l.UnitPrice
                }).ToList()
            };

            var result = await SalesService.CreateSaleAsync(req);

            saveMessage = $"Sale saved in API. Id: {result.SaleId} | Total: {result.Total:0.00}";

            lines.Clear();
            selectedProductId = string.Empty;
            lineQuantity = 1;
            lineUnitPrice = 0m;

            await LoadProductsAsync();

            Nav.NavigateTo("/stock");
        }
        catch (Exception ex)
        {
            saveError = $"Failed to save sale: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }
}